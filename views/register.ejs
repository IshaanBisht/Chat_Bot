<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register Page</title>
    <link rel="stylesheet" href="style.css">

</head>

<body>
    <div class="login-box">
        <form action="/register" method="post" id="register-form">
            <h1>Register</h1>

            <div class="input-login-box">
                <input type="text" name="fName" id="fName" placeholder="First Name" required>
                <label for="fName">First Name</label>
            </div>

            <div class="input-login-box">
                <input type="text" name="lName" id="lName" placeholder="Last Name" required>
                <label for="lName">Last Name</label>
            </div>

            <div class="input-login-box">
                <input type="email" name="email" id="email" placeholder="Email" required autocomplete="email"> 
                <label for="email">Email</label>
                <img src="image/bxs-user.svg" alt="">   
            </div> 

            <div class="input-login-box">
                <input type="password"  name="password"  placeholder="password" id="password" required>
                <label for="password">Password</label>    
                <img src="image/bxs-lock.svg" id="closedlock">
            </div>

            <button type="submit" class="btn">
                Register
            </button>

            <div class="register-link">
                <p>Already have an account? 
                    <a id="signupbutton" href="/login">Login !!</a>
                </p>
            </div>

        </form>
    </div>

    <script src="script.js"></script>

</body>
</html>